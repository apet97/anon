# -----------------------------------------------------------------------------
# Anon (Pumble anonymous messaging bot) — environment template.
#
# Copy this file to `.env` and fill in values from the Pumble marketplace app
# detail page (https://pumble.com/app/marketplace → your app → Credentials).
# `.env` is gitignored. Never paste real values into this template.
#
# Rotation checklist: SECURITY.md
# -----------------------------------------------------------------------------

# --- Required Pumble credentials ---------------------------------------------

# App ID. 24-character hex string. Appears on the app detail page.
PUMBLE_APP_ID=

# App API key. Format: xpat-<32 hex chars>. Used for server-to-server calls.
PUMBLE_APP_KEY=

# OAuth client secret. Format: xpcls-<32 hex chars>. Used for the OAuth2
# authorization-code exchange when a workspace installs the app.
PUMBLE_APP_CLIENT_SECRET=

# Webhook signing secret. Format: xpss-<32 hex chars>. Used to verify the
# x-pumble-request-signature HMAC header on every inbound webhook.
PUMBLE_APP_SIGNING_SECRET=

# --- Runtime configuration (optional, with defaults) ------------------------

# Absolute or relative path to the SQLite database file. Default: ./data/anon.db
# The `data/` directory is gitignored.
DATABASE_PATH=./data/anon.db

# pino log level: fatal | error | warn | info | debug | trace. Default: info
LOG_LEVEL=info

# HTTP port for the SDK server. Default: 3000
PORT=3000

# node environment: development | test | production. Default: development
NODE_ENV=development
